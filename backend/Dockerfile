# backend/Dockerfile

FROM node:22 AS base
WORKDIR /app

COPY package*.json ./
RUN npm ci


FROM base AS dev
COPY . .
CMD ["npm", "run", "dev"]


FROM base AS build
COPY . .
ARG MONGO_URI
ARG PORT
ARG FIREBASE_SERVICE_ACCOUNT_PATH
ARG JWT_SECRET
ARG GROQ_API_KEY
ARG FLUXORIS_API_BASE_URL
ARG FLUXORIS_CLIENT_ID
ARG FLUXORIS_AUDIENCE
ARG FLUXORIS_SHARED_SECRET

ENV MONGO_URI=$MONGO_URI
ENV PORT=$PORT
ENV FIREBASE_SERVICE_ACCOUNT_PATH=$FIREBASE_SERVICE_ACCOUNT_PATH
ENV JWT_SECRET=$JWT_SECRET
ENV GROQ_API_KEY=$GROQ_API_KEY
ENV FLUXORIS_API_BASE_URL=$FLUXORIS_API_BASE_URL
ENV FLUXORIS_CLIENT_ID=$FLUXORIS_CLIENT_ID
ENV FLUXORIS_AUDIENCE=$FLUXORIS_AUDIENCE
ENV FLUXORIS_SHARED_SECRET=$FLUXORIS_SHARED_SECRET
RUN npm run build


FROM node:22 AS prod
WORKDIR /app

COPY --from=build /app/package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist

EXPOSE 5001
CMD ["node", "dist/src/server.js"]