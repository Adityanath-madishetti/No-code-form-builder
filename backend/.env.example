PORT=5000

# Required: Mongo connection string
MONGO_URI=mongodb://ncfb_admin:ncfb_password@localhost:27018/nocode_form_builder?authSource=admin
MONGO_DB=nocode_form_builder
PORT=5001

# Recommended: set your own JWT secret for local dev
JWT_SECRET=change-me-local-dev

# Optional: AI generation (leave empty to disable AI routes gracefully)
GROQ_API_KEY=

# Optional: Firebase Admin (only needed for Firebase-based auth paths)
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Optional: Fluxoris partner integration bridge
# Used by POST /api/partner/fluxoris/exchange-token
FLUXORIS_API_BASE_URL=http://localhost:8000/api
FLUXORIS_CLIENT_ID=nocode_form_builder
FLUXORIS_AUDIENCE=fluxoris-partner-exchange
FLUXORIS_SHARED_SECRET=

# Optional: demo user used by npm run seed:demo
DEMO_USER_EMAIL=demo@nocodeformbuilder.app
