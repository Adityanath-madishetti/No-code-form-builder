# Partner backend base URL (required for login/forms API)
VITE_API_URL=http://localhost:5000

# Backward-compatible alias (either works in current code)
# VITE_API_BASE_URL=http://localhost:5000

# Optional: Fluxoris MFE remote + API (for integration dry-run page)
VITE_FLUXORIS_REMOTE_URL=http://localhost:5174/assets/remoteEntry.js
VITE_FLUXORIS_API_BASE_URL=http://localhost:8000/api

